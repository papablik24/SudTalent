rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins collection (manual entry or bootstrap)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allowing write for this dev environment bootstrap
    }

    // Authorized Phones - Allow public get for login check
    match /authorized_phones/{phoneId} {
      allow get: if true;
      allow list: if isSignedIn(); // Allow any signed in user to list for now (mockup)
      allow write: if isSignedIn(); // Allow any signed in user to write for now (mockup)
    }

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() || userId.startsWith('mock_');
      allow list: if isSignedIn(); // Allow listing users for authenticated users (admin logic handles filtering)
      allow write: if isOwner(userId) || isAdmin() || userId.startsWith('mock_');
      
      match /demos/{demoId} {
        allow read, write: if isSignedIn() || userId.startsWith('mock_');
      }
    }

    // Profiles
    match /profiles/{userId} {
      allow get: if isSignedIn() || userId.startsWith('mock_');
      allow list: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin() || userId.startsWith('mock_');
    }

    // Demos (Top level collection if used that way)
    match /demos/{demoId} {
      allow get: if isSignedIn() || demoId.startsWith('mock_');
      allow list: if isSignedIn();
      allow write: if isSignedIn(); // In this mockup, allow any signed in user to add demos
    }

    // Test connection path
    match /test/connection {
      allow get: if true;
    }
  }
}
